generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  token     String   @unique @default(cuid())
  createdAt DateTime @default(now())

  operators Operator[]
  sessions  ChatSession[]
  settings  WorkspaceSettings?
}

model WorkspaceSettings {
  id          String    @id @default(cuid())
  workspaceId String    @unique
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  greeting       String   @default("Здравствуйте! Чем могу помочь?")
  offlineText    String   @default("Мы сейчас офлайн. Оставьте сообщение — ответим в рабочее время.")
  primaryColor   String   @default("#F26522")
  quickReplies   String[] @default([])
  operatorName   String   @default("Поддержка")
  operatorAvatar String?
}

model Operator {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  name       String
  email      String
  password   String
  avatar     String?
  isOnline   Boolean  @default(false)
  lastSeenAt DateTime?
  createdAt  DateTime @default(now())

  sessions           ChatSession[]
  pushSubscriptions  PushSubscription[]

  @@unique([workspaceId, email])
}

model ChatSession {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  operatorId String?
  operator   Operator? @relation(fields: [operatorId], references: [id])

  visitorId    String  @default(cuid())
  visitorName  String?
  visitorEmail String?
  visitorPage  String?

  channel    String  @default("web")
  externalId String?

  status         String   @default("waiting")
  postponedUntil DateTime?
  closedAt       DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  messages ChatMessage[]

  @@unique([channel, externalId])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  sender    String
  text      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PushSubscription {
  id         String   @id @default(cuid())
  operatorId String
  operator   Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  endpoint   String   @unique
  p256dh     String
  auth       String
  createdAt  DateTime @default(now())
}
